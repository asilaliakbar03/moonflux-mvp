# ─────────────────────────────────────────────────────────────────────────────
# MoonFluxx Environment Variables
# Copy this file to .env.local and fill in your keys
# ─────────────────────────────────────────────────────────────────────────────

# ── SOLANA RPC ────────────────────────────────────────────────────────────────
# Get a free API key at https://helius.dev
# Replace the URL below with your Helius RPC endpoint
NEXT_PUBLIC_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Helius API key (for webhooks + enhanced transactions)
HELIUS_API_KEY=YOUR_HELIUS_KEY
HELIUS_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# ── PRICE DATA APIs ───────────────────────────────────────────────────────────
# Birdeye: https://birdeye.so/pricing
BIRDEYE_API_KEY=YOUR_BIRDEYE_KEY

# Jupiter (free, no key needed for basic price API)
NEXT_PUBLIC_JUPITER_PRICE_URL=https://price.jup.ag/v4/price

# DexScreener (free, no key needed)
NEXT_PUBLIC_DEXSCREENER_URL=https://api.dexscreener.com/latest

# ── DATABASE (Supabase) ───────────────────────────────────────────────────────
# Create a free project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ── CACHE (Upstash Redis) ─────────────────────────────────────────────────────
# Create a free database at https://upstash.com
UPSTASH_REDIS_REST_URL=https://YOUR_REDIS.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_REDIS_TOKEN

# ── AI APIs ───────────────────────────────────────────────────────────────────
# Google Gemini API (for narrative radar + risk scoring)
GOOGLE_AI_API_KEY=YOUR_GEMINI_KEY
# Or OpenAI
OPENAI_API_KEY=YOUR_OPENAI_KEY

# ── AUTH ──────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000
