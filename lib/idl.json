        { "name": "newFeeRecipient", "type": "publicKey" },
        { "name": "newUsdcMint",     "type": "publicKey" },
        { "name": "newUsdtMint",     "type": "publicKey" }
      ]
    },
    {
      "name": "togglePause",
      "accounts": [
        { "name": "globalConfig", "isMut": true,  "isSigner": false },
        { "name": "admin",        "isMut": false, "isSigner": true  }
      ],
      "args": []
    },
    {
      "name": "createPool",
      "accounts": [
        { "name": "bondingCurve",           "isMut": true,  "isSigner": false },
        { "name": "solVault",               "isMut": true,  "isSigner": false },
        { "name": "curveTokenAccount",      "isMut": true,  "isSigner": false },
        { "name": "mint",                   "isMut": true,  "isSigner": false },
        { "name": "creator",                "isMut": true,  "isSigner": true  },
        { "name": "quoteMint",              "isMut": false, "isSigner": false },
        { "name": "tokenProgram",           "isMut": false, "isSigner": false },
        { "name": "associatedTokenProgram", "isMut": false, "isSigner": false },
        { "name": "systemProgram",          "isMut": false, "isSigner": false },
        { "name": "globalConfig",           "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "metadataUri", "type": "string" },
        { "name": "quoteType",   "type": "u8"     }
      ]
    },
    {
      "name": "buy",
      "accounts": [
        { "name": "bondingCurve",      "isMut": true,  "isSigner": false },
        { "name": "solVault",          "isMut": true,  "isSigner": false },
        { "name": "curveTokenAccount", "isMut": true,  "isSigner": false },
        { "name": "userTokenAccount",  "isMut": true,  "isSigner": false },
        { "name": "mint",              "isMut": false, "isSigner": false },
        { "name": "user",              "isMut": true,  "isSigner": true  },
        { "name": "globalConfig",      "isMut": false, "isSigner": false },
        { "name": "feeRecipient",      "isMut": true,  "isSigner": false },
        { "name": "tokenProgram",      "isMut": false, "isSigner": false },
        { "name": "systemProgram",     "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "amountIn",      "type": "u64" },
        { "name": "minTokensOut",  "type": "u64" }
      ]
    },
    {
      "name": "sell",
      "accounts": [
        { "name": "bondingCurve",      "isMut": true,  "isSigner": false },
        { "name": "solVault",          "isMut": true,  "isSigner": false },
        { "name": "curveTokenAccount", "isMut": true,  "isSigner": false },
        { "name": "userTokenAccount",  "isMut": true,  "isSigner": false },
        { "name": "mint",              "isMut": false, "isSigner": false },
        { "name": "user",              "isMut": true,  "isSigner": true  },
        { "name": "globalConfig",      "isMut": false, "isSigner": false },
        { "name": "feeRecipient",      "isMut": true,  "isSigner": false },
        { "name": "tokenProgram",      "isMut": false, "isSigner": false },
        { "name": "systemProgram",     "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "amountTokens", "type": "u64" },
        { "name": "minSolOut",    "type": "u64" }
      ]
    },
    {
      "name": "migrate",
      "accounts": [
        { "name": "bondingCurve",          "isMut": true,  "isSigner": false },
        { "name": "solVault",              "isMut": true,  "isSigner": false },
        { "name": "curveTokenAccount",     "isMut": true,  "isSigner": false },
        { "name": "mint",                  "isMut": false, "isSigner": false },
        { "name": "migrationWallet",       "isMut": true,  "isSigner": false },
        { "name": "migrationTokenAccount", "isMut": true,  "isSigner": false },
        { "name": "globalConfig",          "isMut": false, "isSigner": false },
        { "name": "admin",                 "isMut": false, "isSigner": true  },
        { "name": "tokenProgram",          "isMut": false, "isSigner": false },
        { "name": "systemProgram",         "isMut": false, "isSigner": false }
      ],
      "args": []
    }
  ],
  "accounts": [
    {
      "name": "GlobalConfig",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "admin",          "type": "publicKey" },
          { "name": "feeRecipient",   "type": "publicKey" },
          { "name": "feeBps",         "type": "u16"       },
          { "name": "targetCap",      "type": "u64"       },
          { "name": "targetCapUsdc",  "type": "u64"       },
          { "name": "paused",         "type": "bool"      },
          { "name": "usdcMint",       "type": "publicKey" },
          { "name": "usdtMint",       "type": "publicKey" }
        ]
      }
    },
    {
      "name": "BondingCurve",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "mint",                 "type": "publicKey" },
          { "name": "creator",              "type": "publicKey" },
          { "name": "virtualSolReserves",   "type": "u64"       },
          { "name": "virtualTokenReserves", "type": "u64"       },
          { "name": "realSolReserves",      "type": "u64"       },
          { "name": "realTokenReserves",    "type": "u64"       },
          { "name": "complete",             "type": "bool"      },
          { "name": "totalFeesCollected",   "type": "u64"       },
          { "name": "createdAt",            "type": "i64"       },
          { "name": "quoteType",            "type": "u8"        },
          { "name": "quoteMint",            "type": "publicKey" },
          { "name": "metadataUri",          "type": "string"    }
        ]
      }
    }
  ],
  "types": [
    {
      "name": "QuoteType",
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "Sol"  },
          { "name": "Usdc" },
          { "name": "Usdt" }
        ]
      }
    }
  ],
  "errors": [
    { "code": 6000, "name": "CurveComplete",        "msg": "The bonding curve has reached its target and trading is locked." },
    { "code": 6001, "name": "CurveNotComplete",     "msg": "The bonding curve has not graduated yet. Migration is not allowed." },
    { "code": 6002, "name": "InvalidAmount",        "msg": "Invalid amount: must be greater than zero." },
    { "code": 6003, "name": "SlippageExceeded",     "msg": "Slippage tolerance exceeded. Try increasing slippage or reducing trade size." },
    { "code": 6004, "name": "InsufficientTokens",   "msg": "Insufficient tokens remaining in the bonding curve." },
    { "code": 6005, "name": "InsufficientSol",      "msg": "Insufficient SOL reserves in the bonding curve." },
    { "code": 6006, "name": "MathOverflow",         "msg": "Integer overflow in bonding curve math." },
    { "code": 6007, "name": "Unauthorized",         "msg": "Unauthorized: only the admin can call this instruction." },
    { "code": 6008, "name": "InvalidFeeRecipient",  "msg": "The fee_recipient provided does not match the on-chain GlobalConfig." },
    { "code": 6009, "name": "ProgramPaused",        "msg": "The program is currently paused by the admin." },
    { "code": 6010, "name": "FeeTooHigh",           "msg": "Fee too high: maximum allowed is 500 bps (5%)." },
    { "code": 6011, "name": "InvalidQuoteType",     "msg": "Invalid quote_type: must be 0 (SOL), 1 (USDC), or 2 (USDT)." },
    { "code": 6012, "name": "InvalidQuoteMint",     "msg": "The quote_mint provided does not match the on-chain GlobalConfig for this quote type." },
    { "code": 6013, "name": "UnsupportedQuoteType", "msg": "USDC/USDT quote curves are not yet live. Use SOL (quote_type=0) for now." },
    { "code": 6014, "name": "MetadataUriTooLong",   "msg": "Metadata URI exceeds maximum length of 200 characters." }
  ]
}
